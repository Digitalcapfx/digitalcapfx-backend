# Server
PORT=8080
ENV=development
DEBUG=true

# Database
DATABASE_URL=postgres://digitalfx:localpass@localhost:5432/digitalfx?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# Payments API (WaaS)
PAYMENTS_API_URL=https://payments.rach.finance
PAYMENTS_API_KEY=

# CaaS API (Crypto abstraction wallets / P2P by phone)
CAAS_API_URL=https://caas.rach.finance
CAAS_API_KEY=

# HUB2 (local payment methods — Mobile Money, XAF/XOF on/off ramp)
HUB2_BASE_URL=https://api.hub2.io
HUB2_API_KEY=
HUB2_SECRET_KEY=
HUB2_MODE=sandbox           # sandbox | production

# GCP
GCP_PROJECT_ID=
KYC_BUCKET=digitalfx-kyc-documents
